# Environment Variables for Production
# Copy this file to .env and fill in your actual credentials

# Africa's Talking credentials
# For sandbox testing: AT_USERNAME=sandbox, get API key from account.africastalking.com
AT_USERNAME=sandbox
AT_API_KEY=your_africas_talking_api_key_here

# Your USSD service code channel (the number after *384*)
# Example: if your code is *384*5678#, set this to 5678
# Register your channel at: account.africastalking.com > USSD > Create Channel
AT_SERVICE_CODE=your_channel_number_here

# Optional: Registered Sender ID for outbound SMS (e.g. IEA_Platform)
# Leave blank to use a shared shortcode from AT
SENDER_ID=IEA_Platform
